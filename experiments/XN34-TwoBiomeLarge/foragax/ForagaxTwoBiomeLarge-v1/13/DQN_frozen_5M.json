{
    "agent": "DQN_frozen_5M",
    "problem": "Foragax",
    "total_steps": 10000000,
    "episode_cutoff": -1,
    "metaParameters": {
        "initial_epsilon": 1.0,
        "final_epsilon": 0.05,
        "epsilon_linear_decay": 8000,
        "target_refresh": 1,
        "buffer_size": 10000,
        "buffer_min_size": 32,
        "batch": 32,
        "environment": {
            "env_id": "ForagaxTwoBiomeLarge-v1",
            "aperture_size": 13,
            "observation_type": "rgb"
        },
        "experiment": {
            "seed_offset": 0
        },
        "gamma": 0.99,
        "optimizer": {
            "name": "Adam",
            "alpha": 0.001,
            "beta1": 0.9,
            "beta2": 0.9,
            "eps": 1e-08
        },
        "representation": {
            "type": "ForagerNet",
            "hidden": 64,
            "layers": 1,
            "use_layernorm": false,
            "conv": "Conv2D",
            "scalar_features": ""
        },
        "update_freq": 1,
        "freeze_steps": 5000000
    }
}