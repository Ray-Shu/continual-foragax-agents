{
    "agent": "DQN_ReDo_PreActLN",
    "problem": "Foragax",
    "total_steps": 10000000,
    "episode_cutoff": -1,
    "metaParameters": {
        "epsilon": 0.05,
        "use_past_action": true,
        "use_past_reward": true,
        "target_refresh": 128,
        "buffer_size": 1000,
        "buffer_min_size": 50,
        "batch": 32,
        "environment": {
            "env_id": "ForagaxSquareWaveTwoBiome-v11",
            "aperture_size": 9,
			"observation_type": "color"
        },
        "experiment": {
            "seed_offset": 0
        },
        "gamma": 0.99,
        "optimizer": {
            "name": "Adam",
            "alpha": [
                0.003,
                0.001,
                0.0003,
                0.0001,
                3e-05
            ],
            "beta1": 0.9,
            "beta2": 0.999,
            "eps": 1e-5
        },
        "representation": {
            "type": "ForagerNet",
            "hidden": 64,
            "layers": 2,
            "conv": "None",
            "use_layernorm": true,
            "preactivation_layer_norm": true
        },
        "update_freq": 4,
        "redo_freq": 10000,
        "redo_threshold": 0.025,
        "redo_reset_layernorm": true
    }
}
